# 监听地址/端口:仅本机,交给 1Panel 反代
HOST=127.0.0.1
PORT=8787

# Cookie 签名 + Token 加密密钥。生产务必设置为一段固定的随机串(>=32 字节)。
# 生成方法: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# 不设置时,服务会在 data/secret.key 自动生成并复用。
APP_SECRET=

# 浏览器经 1Panel 以 HTTPS 访问时设为 true(让会话 Cookie 带 Secure 属性)
COOKIE_SECURE=false

# 仅当 1Panel 以子路径反代时设置(需与前端构建的 BASE_PATH 一致),如 /dns
# BASE_PATH=

# 可选:数据目录与数据库路径
# DATA_DIR=./data
# DB_PATH=./data/cf-dns-panel.db

# 日志级别: trace|debug|info|warn|error
LOG_LEVEL=info
